LLMOD_API_KEY=your-llmod-api-key
LLMOD_BASE_URL=https://api.llmod.ai/v1
LLMOD_MODEL=MB5R2CF-azure/gpt-5.4-mini
LLMOD_EMBEDDING_MODEL=MB5R2CF-azure/text-embedding-3-small
TMDB_API_KEY=your-tmdb-api-key

# Pinecone and Supabase are OPTIONAL. The app runs fully without them:
# RAG falls back to a local JSONL index, and run-logging is best-effort.
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=cinematch-movies
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# RAG backend: "local" (default, no Pinecone needed) or "pinecone"
RAG_BACKEND=local
RAG_DOCUMENTS_PATH=data/processed/rag_documents.jsonl

# Optional tunables (defaults shown)
MAX_PASSES=2
MAX_TOOL_CALLS=8
RAG_TOP_K=10
MIN_CANDIDATES=3
MAX_CANDIDATES=5
